# Lithic Environment Variables
# Copy this file to .env and fill in your values

# Provider Configuration
# Options: openai, anthropic, openrouter, ollama
LITHIC_PROVIDER=openai

# Model Configuration
# Examples: gpt-4, claude-3-opus, llama2
LITHIC_MODEL=gpt-4

# Graph Directory
# Where to store the project graph
LITHIC_GRAPH_DIR=graphify-out

# Response Mode
# Options: concise, detailed, normal
LITHIC_RESPONSE_MODE=concise

# Verbose Output
LITHIC_VERBOSE=false

# API Keys (use one based on your provider)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# Legacy Support (optional)
# UDA_PROVIDER=openai
# UDA_MODEL=gpt-4
